# Version configuration for Coder workspace infrastructure
# This file is the single source of truth for version numbers
# Updated automatically by GitHub Actions workflows

# Vibe Kanban install mode:
#   source   = clone + build from source (always works, ~5-8min)
#   prebuilt = download tarball from GitHub Release (~30s, run prebuild-vibe-kanban.yml first)
VK_SOURCE=source

# Vibe Kanban git reference (tag or branch name)
# Examples: v0.1.18, main
# Note: commit SHAs are NOT supported (git clone --branch requires a named ref)
VK_GIT_REF=v0.1.18

# Vibe Kanban remote API base URL (set at build time)
# This is baked into the frontend build via VITE_VK_SHARED_API_BASE
# Only used when VK_SOURCE=source (prebuilt tarball already has this baked in)
VK_API_BASE=https://vk-remote.holagence.com

# Coder workspace image tag (independent versioning)
# Incremented when image changes beyond vibe-kanban version bump
CODER_IMAGE_TAG=1.3
